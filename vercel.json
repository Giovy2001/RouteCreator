{
  "builds": [
    {
      "src": "main.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/database_cleanup.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/database_cleanup",
      "dest": "/api/database_cleanup.py"
    },
    {
      "src": "/(.*)",
      "dest": "/main.py"
    }
  ],
  "crons": [
    {
      "path": "/api/database_cleanup",
      "schedule": "0 16 * * 3"
    }
  ]
}